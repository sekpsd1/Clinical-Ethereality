# Production App
NEXT_PUBLIC_APP_NAME="Clinical Ethereality"
NEXT_PUBLIC_APP_URL="https://app.example.com"
NODE_ENV="production"

# Production Database
# Use the approved production managed MySQL database only.
DATABASE_URL="mysql://USER:PASSWORD@PRODUCTION_HOST:3306/clinical_ethereality"

# Authentication
JWT_SECRET="replace-with-a-production-secret-at-least-32-characters"
JWT_ISSUER="clinical-ethereality"
JWT_ACCESS_TOKEN_TTL="15m"
JWT_REFRESH_TOKEN_TTL="30d"
ENABLE_DEV_AUTH_BYPASS="false"

# LINE LIFF, production channel
NEXT_PUBLIC_LINE_LIFF_ID="production-liff-id"
LINE_CHANNEL_ID="production-line-channel-id"
LINE_CHANNEL_SECRET="production-line-channel-secret"
LINE_LOGIN_CALLBACK_URL="https://app.example.com/api/auth/line/callback"

# Email, production provider
EMAIL_PROVIDER="resend"
RESEND_API_KEY=""
EMAIL_FROM="Clinical Ethereality <no-reply@example.com>"

# SMS, optional
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Video Consultations, production app
ZOOM_SDK_KEY=""
ZOOM_SDK_SECRET=""
ZOOM_ACCOUNT_ID=""
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""
ZOOM_WEBHOOK_SECRET=""

# Payments, production credentials
THAI_QR_PROMPTPAY_ID=""
SLIP_VERIFICATION_PROVIDER=""
SLIP_VERIFICATION_API_URL=""
SLIP_VERIFICATION_API_KEY=""
SLIPOK_BRANCH_ID=""
SLIP_VERIFICATION_EXPECTED_RECEIVER_NAME=""
PAYMENT_WEBHOOK_SECRET=""

# Cloudinary, production folder/account if selected
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Object Storage, production bucket only
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET="clinical-ethereality-production"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""

# Monitoring
SENTRY_DSN=""

# Security And Compliance Feature Flags
AUDIT_LOG_RETENTION_DAYS="2555"
ENABLE_PATIENT_PORTAL="false"
ENABLE_ONLINE_BOOKING="false"
ENABLE_PAYMENTS="false"
ENABLE_AI_FEATURES="false"
ENABLE_COMMUNITY="false"
ENABLE_VIDEO_CONSULTATIONS="false"
ENABLE_PRESCRIPTIONS="false"
