# Staging App
NEXT_PUBLIC_APP_NAME="Clinical Ethereality Staging"
NEXT_PUBLIC_APP_URL="https://staging.example.com"
NODE_ENV="production"

# Staging Database
# Use a dedicated staging database. Never point staging at production.
DATABASE_URL="mysql://USER:PASSWORD@STAGING_HOST:3306/clinical_ethereality_staging"

# Authentication
JWT_SECRET="replace-with-a-staging-secret-at-least-32-characters"
JWT_ISSUER="clinical-ethereality"
JWT_ACCESS_TOKEN_TTL="15m"
JWT_REFRESH_TOKEN_TTL="30d"
ENABLE_DEV_AUTH_BYPASS="false"

# LINE LIFF, staging channel
NEXT_PUBLIC_LINE_LIFF_ID="staging-liff-id"
LINE_CHANNEL_ID="staging-line-channel-id"
LINE_CHANNEL_SECRET="staging-line-channel-secret"
LINE_LOGIN_CALLBACK_URL="https://staging.example.com/api/auth/line/callback"

# Email, optional for staging
EMAIL_PROVIDER="resend"
RESEND_API_KEY=""
EMAIL_FROM="Clinical Ethereality Staging <no-reply-staging@example.com>"

# SMS, optional
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Video Consultations, staging/test app
ZOOM_SDK_KEY=""
ZOOM_SDK_SECRET=""
ZOOM_ACCOUNT_ID=""
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""
ZOOM_WEBHOOK_SECRET=""

# Payments, staging/test credentials only
THAI_QR_PROMPTPAY_ID=""
SLIP_VERIFICATION_PROVIDER=""
SLIP_VERIFICATION_API_URL=""
SLIP_VERIFICATION_API_KEY=""
SLIPOK_BRANCH_ID=""
SLIP_VERIFICATION_EXPECTED_RECEIVER_NAME=""
PAYMENT_WEBHOOK_SECRET=""

# Cloudinary, staging folder/account if selected
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Object Storage, staging bucket only
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET="clinical-ethereality-staging"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""

# Monitoring
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0"
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Security And Compliance Feature Flags
AUDIT_LOG_RETENTION_DAYS="2555"
ENABLE_PATIENT_PORTAL="false"
ENABLE_ONLINE_BOOKING="false"
ENABLE_PAYMENTS="false"
ENABLE_AI_FEATURES="false"
ENABLE_COMMUNITY="false"
ENABLE_VIDEO_CONSULTATIONS="false"
ENABLE_PRESCRIPTIONS="false"
